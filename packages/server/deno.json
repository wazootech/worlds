{
  "name": "@wazoo/worlds-server",
  "version": "0.0.1",
  "exports": {
    ".": "./src/mod.ts",
    "./serve": "./src/main.ts"
  },
  "imports": {
    "#/": "./src/",
    "@hono/hono": "jsr:@hono/hono@^4.0.0",
    "@std/http": "jsr:@std/http@^1.0.25",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/encoding": "jsr:@std/encoding@^1.0.5"
  },
  "tasks": {
    "start": "deno serve -A --env ./src/main.ts",
    "generate": "deno -A jsr:@fartlabs/sql-embedder@0.0.5 ./"
  },
  "publish": {
    "exclude": ["**/*.test.ts", "**/*_test.ts"]
  }
}
