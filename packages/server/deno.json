{
  "name": "@wazoo/worlds-server",
  "version": "0.0.1",
  "exports": {
    ".": "./src/mod.ts",
    "./serve": "./src/main.ts"
  },
  "imports": {
    "#/": "./src/",
    "@fartlabs/rt": "jsr:@fartlabs/rt@^0.0.11",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.1.0",
    "@std/http": "jsr:@std/http@^1.0.25",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@wazoo/worlds-ai-sdk": "../ai-sdk/src/mod.ts",
    "@wazoo/worlds-sdk": "../worlds/src/mod.ts"
  },
  "tasks": {
    "start": "deno serve -A --env ./src/main.ts",
    "generate": "deno -A jsr:@fartlabs/sql-embedder@0.0.5 ./"
  },
  "publish": {
    "exclude": ["**/*.test.ts", "**/*_test.ts"]
  }
}
