@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix worlds: <https://schema.wazoo.dev#> .

# Core Worlds Ontology
# High-stakes verifiable context for autonomous agents.

<https://schema.wazoo.dev#> a owl:Ontology ;
    rdfs:label "Core Worlds Ontology" ;
    rdfs:comment "Standard vocabulary for agentic memory, verifiable context, and recursive state refinement." .

# Classes

worlds:World a rdfs:Class ;
    rdfs:label "World" ;
    rdfs:comment "The root container for a stateful knowledge graph sandbox." .

worlds:Item a rdfs:Class ;
    rdfs:label "Item" ;
    rdfs:comment "A unique semantic entity defined by an IRI within a World." .

worlds:Fact a rdfs:Class ;
    rdfs:label "Fact" ;
    rdfs:comment "A verified triple recorded in the chronological, append-only ledger." .

worlds:Agent a rdfs:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "An entity with agency, such as an AI model or a human user." .

worlds:Preference a rdfs:Class ;
    rdfs:label "Preference" ;
    rdfs:comment "A recorded value alignment or reward signal." .

worlds:Observation a rdfs:Class ;
    rdfs:label "Observation" ;
    rdfs:comment "A raw data input or sensory event trapped by an agent." .

# Properties

worlds:hasItem a rdf:Property ;
    rdfs:label "has item" ;
    rdfs:comment "Connects a World to a constituent Item." ;
    rdfs:domain worlds:World ;
    rdfs:range worlds:Item .

worlds:hasFact a rdf:Property ;
    rdfs:label "has fact" ;
    rdfs:comment "Connects an Item or World to a recorded Fact." ;
    rdfs:range worlds:Fact .

worlds:hasPreference a rdf:Property ;
    rdfs:label "has preference" ;
    rdfs:comment "Links a Fact or Item to a human or autonomous preference signal." ;
    rdfs:range worlds:Preference .

worlds:hasReward a rdf:Property ;
    rdfs:label "has reward" ;
    rdfs:comment "A numerical score (0.0 to 1.0) representing an alignment signal." ;
    rdfs:domain worlds:Preference ;
    rdfs:range xsd:decimal .

worlds:discoveredBy a rdf:Property ;
    rdfs:label "discovered by" ;
    rdfs:comment "Connects a Fact or Item to the Agent that first proposed it." ;
    rdfs:range worlds:Agent .

worlds:verifiedBy a rdf:Property ;
    rdfs:label "verified by" ;
    rdfs:comment "Connects a Fact to the Agent or User that verified its truth." ;
    rdfs:range worlds:Agent .

worlds:assertedAt a rdf:Property ;
    rdfs:label "asserted at" ;
    rdfs:comment "The precise ISO timestamp when a fact was committed to the ledger." ;
    rdfs:domain worlds:Fact ;
    rdfs:range xsd:dateTime .
