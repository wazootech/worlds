{
  "name": "@wazoo/worlds-sdk",
  "version": "0.1.0",
  "exports": {
    ".": "./src/mod.ts",
    "./config": "./src/config.ts",
    "./engine": "./src/engine/service.ts",
    "./remote": "./src/sdk/client.ts",
    "./schema": "./src/schema.ts",
    "./server": "./src/server/secure-worlds.ts",
    "./testing": "./src/testing/context.ts"
  },
  "imports": {
    "#/": "./src/",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "@hono/hono": "jsr:@hono/hono@^4.0.0",
    "@langchain/textsplitters": "npm:@langchain/textsplitters@^1.0.1",
    "@comunica/query-sparql-rdfjs-lite": "npm:@comunica/query-sparql-rdfjs-lite@^5.1.3",
    "jsonld-context-parser": "npm:jsonld-context-parser@2.3.0",
    "@types/n3": "npm:@types/n3@^1.26.1",
    "@std/http": "jsr:@std/http@^1.0.25",
    "ollama-ai-provider": "npm:ollama-ai-provider@^1.2.0",
    "@openrouter/ai-sdk-provider": "npm:@openrouter/ai-sdk-provider@^2.8.0",
    "ai": "npm:ai@^4.0.0",
    "ollama": "npm:ollama@^0.5.12",
    "rdf-canonize": "npm:rdf-canonize@^5.0.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.5",
    "@std/path": "jsr:@std/path@^1.0.8",
    "n3": "npm:n3@^2.0.3",
    "cross-fetch/polyfill": "npm:cross-fetch@3.2.0/dist/node-polyfill.js"
  },
  "tasks": {
    "test": "deno test -A",
    "generate": "deno run -A src/spec/generate.ts"
  },
  "publish": {
    "exclude": ["**/*.test.ts", "**/*_test.ts"]
  }
}
