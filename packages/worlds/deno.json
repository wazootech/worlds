{
  "name": "@wazoo/worlds-sdk",
  "version": "0.0.1",
  "exports": {
    ".": "./src/mod.ts",
    "./engine": "./src/worlds/local.ts",
    "./remote": "./src/worlds/remote.ts",
    "./schema": "./src/schemas/mod.ts",
    "./schema/world": "./src/schemas/world.ts",
    "./schema/sparql": "./src/schemas/sparql.ts",
    "./schema/search": "./src/schemas/search.ts",
    "./schema/source": "./src/schemas/source.ts",
    "./schema/registry": "./src/schemas/registry.ts",
    "./types": "./src/core/types.ts",
    "./testing": "./src/core/engine-context.ts"
  },
  "imports": {
    "#/": "./src/",
    "@libsql/client": "npm:@libsql/client@^0.17.0",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "@fartlabs/rt": "jsr:@fartlabs/rt@^0.0.11",
    "@langchain/textsplitters": "npm:@langchain/textsplitters@^1.0.1",
    "@comunica/query-sparql-rdfjs-lite": "npm:@comunica/query-sparql-rdfjs-lite@^5.1.3",
    "@types/n3": "npm:@types/n3@^1.26.1",
    "@std/http": "jsr:@std/http@^1.0.25",
    "ollama-ai-provider": "npm:ollama-ai-provider@^1.2.0",
    "rdf-canonize": "npm:rdf-canonize@^5.0.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.5",
    "n3": "npm:n3@^1.21.0",
    "zod": "npm:zod@^4.3.6"
  },
  "tasks": {
    "test": "deno test -A",
    "generate": "deno -A jsr:@fartlabs/sql-embedder@0.0.5 ./"
  },
  "publish": {
    "exclude": ["**/*.test.ts", "**/*_test.ts"]
  }
}
