{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Worlds Docs",
  "colors": {
    "primary": "#D97706",
    "light": "#F59E0B",
    "dark": "#78350F"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "favicon": "/images/wazoo.svg",
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Worlds Docs"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Developer Platform",
        "icon": "code",
        "groups": [
          "overview",
          "quickstart",
          "vibe-coding",
          {
            "group": "Concepts",
            "pages": [
              "concepts/how-it-works",
              "concepts/neuro-symbolic",
              "concepts/memory-systems",
              "concepts/sparql-reasoning",
              "concepts/hybrid-search",
              "concepts/knowledge-primitives",
              "concepts/privacy-and-evolution"
            ]
          },
          {
            "group": "Infrastructure",
            "pages": [
              "infrastructure/edge-first",
              "infrastructure/server-hosting",
              "infrastructure/local-setup",
              "infrastructure/configuration",
              "infrastructure/whitepaper",
              "infrastructure/console-hosting",
              "infrastructure/cli-persistence"
            ]
          }
        ]
      },
      {
        "tab": "API Integrations",
        "icon": "plug",
        "groups": [
          {
            "group": "Native SDKs",
            "pages": [
              "api-integrations/native-sdks/index",
              "api-integrations/native-sdks/sdk"
            ]
          },
          {
            "group": "Frameworks",
            "pages": [
              "api-integrations/frameworks/ai-sdk",
              "api-integrations/frameworks/vercel-ai",
              "api-integrations/frameworks/langchain",
              "api-integrations/frameworks/openai"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "book-open",
        "openapi": "openapi.yaml",
        "groups": [
          {
            "group": "API Basics",
            "pages": [
              "api-reference/basics/authentication",
              "api-reference/basics/search",
              "api-reference/basics/sparql",
              "api-reference/basics/specification"
            ]
          },
          {
            "group": "Endpoints",
            "expanded": false,
            "pages": [
              "GET /worlds",
              "POST /worlds",
              "GET /worlds/{world}",
              "PUT /worlds/{world}",
              "DELETE /worlds/{world}",
              "GET /worlds/{world}/search",
              "GET /worlds/{world}/sparql",
              "POST /worlds/{world}/sparql",
              "GET /worlds/{world}/logs",
              "GET /worlds/{world}/export",
              "POST /worlds/{world}/import"
            ]
          }
        ]
      },
      {
        "tab": "Cookbook",
        "icon": "hat-chef",
        "groups": [
          {
            "group": "Guides",
            "pages": [
              "cookbook/guides/social-graphs",
              "cookbook/guides/personal-search",
              "cookbook/guides/cli-tasks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Console",
          "href": "https://console.wazoo.dev",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/wazootech/worlds"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to Console",
      "href": "https://console.wazoo.dev"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/wazootech/",
      "x": "https://x.com/wazootech",
      "github": "https://github.com/wazootech"
    }
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-V64G870T6Z"
    }
  }
}
