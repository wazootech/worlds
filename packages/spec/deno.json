{
  "name": "@wazoo/worlds-spec",
  "version": "0.0.1",
  "exports": {
    ".": "./types.gen.ts",
    "./zod": "./zod.gen.ts"
  },
  "imports": {
    "#/": "./",
    "openapi-types": "npm:openapi-types@^12.1.3"
  },
  "tasks": {
    "generate": "deno run -A spec.ts"
  },
  "lint": {
    "exclude": ["*.gen.ts", "schemas/*.ts", "spec.ts"]
  },
  "publish": {
    "exclude": ["**/*.test.ts", "**/*_test.ts"]
  }
}
