{
  "name": "@wazoo/worlds-spec",
  "version": "1.0.0",
  "exports": {
    ".": "./types.gen.ts",
    "./zod": "./zod.gen.ts",
    "./generate": "./generate.ts"
  },
  "imports": {
    "#/": "./",
    "openapi3-ts": "npm:openapi3-ts@^4.5.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.0"
  },
  "tasks": {
    "generate": "deno run -A generate.ts"
  },
  "lint": {
    "exclude": [
      "*.gen.ts",
      "schemas/*.ts",
      "generate.ts"
    ]
  },
  "publish": {
    "exclude": ["**/*.test.ts", "**/*_test.ts"],
    "allow-slow-types": true
  }
}
