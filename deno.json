{
  "workspace": [
    "./packages/server",
    "./packages/worlds",
    "./packages/ai-sdk",
    "./packages/cli"
  ],
  "tasks": {
    "install": "npm i --prefix ./packages/console && npm i --prefix ./packages/docs",
    "start": "npm run dev --prefix ./packages/console",
    "start:cli": "deno -A --env=./packages/cli/.env ./packages/cli/main.ts",
    "start:docs": "npm run dev --prefix ./packages/docs",
    "start:server": "deno serve -A --env=./packages/server/.env ./packages/server/src/main.ts",
    "test": "deno test -A --reporter=pretty",
    "lint": "deno lint --json",
    "fmt": "deno fmt --check",
    "check": "deno check",
    "generate": "deno task --cwd packages/worlds generate",
    "publish:dry": "deno publish --dry-run --allow-dirty --quiet",
    "reset:console": "npm run reset --prefix ./packages/console",
    "precommit:console": "npm run precommit --prefix packages/console",
    "precommit:docs": "npm run precommit --prefix packages/docs",
    "precommit:core": {
      "dependencies": ["fmt", "lint", "check", "test", "publish:dry"]
    },
    "precommit": {
      "dependencies": ["precommit:core"]
    }
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@1.0.28",
    "@comunica/query-sparql-rdfjs-lite": "npm:@comunica/query-sparql-rdfjs-lite@^5.1.3",
    "zod": "npm:zod@^4.3.6",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/ulid": "jsr:@std/ulid@1",
    "@std/encoding": "jsr:@std/encoding@^1.0.7",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@libsql/client": "npm:@libsql/client@^0.17.2",
    "@tursodatabase/api": "npm:@tursodatabase/api@^2.0.0",
    "@tensorflow/tfjs": "npm:@tensorflow/tfjs@^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "npm:@tensorflow/tfjs-backend-wasm@^4.22.0",
    "@tensorflow-models/universal-sentence-encoder": "npm:@tensorflow-models/universal-sentence-encoder@^1.3.3",
    "n3": "npm:n3@^2.0.3",
    "shacl-engine": "npm:shacl-engine@^1.1.0",
    "ai": "npm:ai@^6.0.158",
    "@openrouter/ai-sdk-provider": "npm:@openrouter/ai-sdk-provider@^2.5.1",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.29.0"
  },
  "exclude": ["./packages/console", "./packages/docs", "./.gemini"],
  "lint": {
    "exclude": ["scratch"]
  },
  "publish": {
    "exclude": ["**/*.test.ts", "**/*_test.ts"]
  }
}
